# Puerto del API (por defecto 3000)
PORT=3000

# Orígenes permitidos para CORS (separados por coma)
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Carpeta de persistencia JSON (opcional)
# DATA_DIR=./server/data

# --- Extracción de facturas (elige una opción) ---

# Opción A: OpenAI Vision (recomendado para demo con IA)
OPENAI_API_KEY=sk-tu-clave-openai
OPENAI_MODEL=gpt-4o-mini

# Opción B: API personalizada de extracción
# INVOICE_API_URL=https://tu-servicio.com/extract
# INVOICE_API_KEY=tu-token-opcional

# Sin claves configuradas, el API devuelve datos simulados (mock)
