# Puerto del API (por defecto 3000)
PORT=3000

# Orígenes permitidos para CORS (separados por coma)
# Incluye orígenes Capacitor WebView para APK Android
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,https://localhost,capacitor://localhost,http://localhost

# URL del API para inyectar en sync-config.js al compilar APK (npm run build:apk)
# Ejemplos: https://api.tudominio.com  |  http://192.168.1.50:3000 (LAN dev)
CLOUD_API_URL=
# Alias alternativo:
# SYNC_API_URL=

# --- PostgreSQL ---
POSTGRES_USER=vencely
POSTGRES_PASSWORD=vencely
POSTGRES_DB=vencely
DATABASE_URL=postgresql://vencely:vencely@localhost:5432/vencely

# Carpeta de facturas subidas (opcional)
# UPLOADS_DIR=./server/uploads

# --- Extracción de facturas ---

# Proveedor: auto (gemini→openai→tesseract→mock), gemini, openai, tesseract, mock
INVOICE_PROVIDER=auto

# Opción A: Google Gemini Vision (recomendado si tienes clave Gemini)
GEMINI_API_KEY=tu-clave-gemini
GEMINI_MODEL=gemini-2.0-flash

# Opción B: OpenAI Vision (fallback o alternativa)
OPENAI_API_KEY=sk-tu-clave-openai
OPENAI_MODEL=gpt-4o-mini

# Opción C: API personalizada de extracción
# INVOICE_API_URL=https://tu-servicio.com/extract
# INVOICE_API_KEY=tu-token-opcional

# Sin GEMINI_API_KEY ni OPENAI_API_KEY y INVOICE_PROVIDER=auto: Tesseract OCR + heurísticas CO → mock si falla

# --- Autenticación JWT (usuarios) ---
# Obligatorio en producción: mínimo 32 caracteres aleatorios
JWT_SECRET=cambia-este-secreto-jwt-en-produccion

# --- Acceso administrador ---
ADMIN_EMAIL=admin@vencely.app
# Obligatorio en producción: no usar admin123
ADMIN_PASSWORD=admin123
ADMIN_JWT_SECRET=cambia-este-secreto-admin-en-produccion

# En Docker/producción: no crear usuario demo maria@vencely.app salvo que lo habilites
# SEED_DEMO=true
